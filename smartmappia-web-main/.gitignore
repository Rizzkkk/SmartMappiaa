# Safety net for anything that lands at the project root.
# (frontend/ and backend/ each have their own .gitignore too.)

node_modules/
dist/
dist-ssr/
.vite/
build/

# Never commit real environment files — only the .example templates.
.env
.env.*
!.env.example

# Logs & OS/editor cruft
*.log
npm-debug.log*
.DS_Store
.idea/
*.sw?
