# ==========================================================
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env file. NEVER put these in the frontend.
# ==========================================================

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# The SERVICE ROLE key bypasses Row-Level Security. Server only. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Server ---
PORT=4000
# CORS allow-list (comma-separated origins). Leave empty to allow all (dev/pilot).
# Set to the production frontend origin(s) before launch, e.g.
# CORS_ORIGINS=https://smartmappia.com,https://www.smartmappia.com
CORS_ORIGINS=

# --- Payment / testing flags (spec sections 4 and 16) ---
# When true, uploading a proof auto-verifies the booking FOR TESTING ONLY.
# This MUST be false in production.
AUTO_VERIFY_STCPAY_TEST_MODE=true
# stcpay_manual | stcpay_manual_test_auto | moyasar | both
PAYMENT_MODE=stcpay_manual_test_auto

# --- Smart Mappia STC Pay details shown to the passenger (spec section 6) ---
SMART_MAPPIA_STCPAY_NUMBER=05XXXXXXXX
SMART_MAPPIA_STCPAY_NAME=Smart Mappia

# --- Payment proof storage (Supabase Storage) ---
# Create a PRIVATE bucket with this name in the Supabase dashboard.
PAYMENT_PROOF_BUCKET=payment-proofs
# Signed URL lifetimes (seconds) and max upload size (bytes, default 10 MB).
PAYMENT_PROOF_UPLOAD_TTL=900
PAYMENT_PROOF_DOWNLOAD_TTL=3600
PAYMENT_PROOF_MAX_BYTES=10485760

# --- Auth (Supabase JWT) ---
# Accounts whose email is listed here automatically become admins on sign-in
# (comma-separated, case-insensitive). Everyone else is a passenger/driver.
ADMIN_EMAILS=admin123@smartmappia.com

# --- Default admin seed (used by `npm run seed:admin`) ---
# TEST CREDENTIALS — change these before production.
ADMIN_SEED_EMAIL=admin123@smartmappia.com
ADMIN_SEED_PASSWORD=admin123

# (Deprecated) old shared-secret keys — no longer used now that routes
# verify Supabase JWTs. Safe to remove.
# ADMIN_API_KEY=
# DRIVER_API_KEY=

# --- Ledger / payout math (spec section 12) ---
# Commission as a fraction (0.20 = 20%). Manual payment fee is a fixed amount.
PLATFORM_COMMISSION_RATE=0.20
MANUAL_PAYMENT_FEE=0
