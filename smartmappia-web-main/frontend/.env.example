# ==========================================================
# Frontend (Vite) environment. Copy to ".env" and fill in.
# Only VITE_* vars are exposed to the browser — never put the
# Supabase SERVICE ROLE key here (that lives in the backend only).
# ==========================================================

# Base URL of the Smart Mappia backend API.
VITE_API_BASE=http://localhost:4000

# Supabase project (ANON/public key only) — used for Realtime live updates
# and for uploading payment proofs via signed URLs.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Routing (OSRM). Leave UNSET to use the public OSRM demo (testing only,
# rate-limited). For production, point at your self-hosted OSRM or backend proxy,
# e.g. https://yourdomain.com/osrm/route/v1/driving
VITE_OSRM_BASE=

# Tap Payments online checkout. Leave UNSET/false until the Tap merchant API +
# backend /api/payments/:code/tap-charge endpoint are live. While off, the
# "Pay online" button shows a "coming soon" note and manual STC Pay is used.
VITE_TAP_ENABLED=
